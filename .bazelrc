# bazel 9 defaults to bzlmod (WORKSPACE is gone), so no enable flags needed.
build --announce_rc
test --test_output=errors

# The byte-match tests are backend-agnostic; CPU is the default (not a
# requirement) so plain `bazel test` is deterministic on any machine. The GPU
# byte-match lives on the Rust side (Cargo, hardware-gated), not here.
test --test_env=JAX_PLATFORMS=cpu

# Local, machine-specific overrides (gitignored). For dev against a local zorch
# working copy instead of the pinned git_override, add to .bazelrc.user:
#   common --override_module=zorch=/abs/path/to/your/zorch/checkout
try-import %workspace%/.bazelrc.user
